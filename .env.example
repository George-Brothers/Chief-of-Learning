# AI — direct providers (no Vercel AI Gateway).
# DeepSeek is required: it powers the chat/reason/classify roles. Key from platform.deepseek.com.
DEEPSEEK_API_KEY=
# Google/Gemini is optional: it powers the long-context + vision roles. When unset, those roles fall
# back to DeepSeek where possible and the image/OCR path is unavailable. Key from aistudio.google.com.
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional per-role model overrides, as `provider/model-id`. Leave unset to use the defaults in
# lib/models.ts:  chat/reason/classify = deepseek/deepseek-v4-flash   long/vision = google/gemini-2.5-flash
# Set any one to reroute a task. Confirm current model ids against each provider's docs — they drift.
# MODEL_CHAT=
# MODEL_REASON=
# MODEL_CLASSIFY=
# MODEL_LONG=
# MODEL_VISION=

# Telegram bot (from @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Notion (integration token + ids printed by `npm run setup:notion`)
NOTION_TOKEN=
NOTION_EVIDENCE_DB_ID=
NOTION_TODAY_PAGE_ID=
NOTION_SYLLABUS_DB_ID=
NOTION_DECKS_DB_ID=
NOTION_SCORECARD_PAGE_ID=
NOTION_LESSONS_DB_ID=
NOTION_ACTIONQUEUE_DB_ID=
NOTION_ASSIGNMENTS_DB_ID=
NOTION_RETAINED_PAGE_ID=
NOTION_LISTENING_PAGE_ID=
# The four-doc brain (ids printed by `npm run seed:knowledge`)
NOTION_LEDGER_PAGE_ID=
NOTION_STUDYMAP_PAGE_ID=
NOTION_DAILYLOG_PAGE_ID=
NOTION_GRADEBOOK_PAGE_ID=

# Local lesson agent shared secret (agent/ pipeline; any long random string)
AGENT_SECRET=

# Cron protection (any long random string)
CRON_SECRET=

# Web dashboard single-user gate. Set this to enable /dashboard and the Talk-to-Lucy chat (/api/chat).
# Leave EMPTY to keep the dashboard locked (fail closed). The session cookie is an HMAC of this value
# keyed by CRON_SECRET, so the raw password is never stored client-side.
DASHBOARD_PASSWORD=

# M3 semantic retrieval index (Neon Postgres + pgvector). BOTH optional: retrieval is additive over
# Notion (the source of truth), so an unconfigured index just falls back to Notion-only — the bot
# never breaks. To enable: provision a Neon database, run `npm run db:migrate`, then `npm run sync:index`.
# DATABASE_URL — Neon Postgres connection string (the derived read index).
DATABASE_URL=
# OPENAI_API_KEY — embeddings (text-embedding-3-small, 1536 dims) AND the vision-role fallback
# (openai/gpt-4o-mini) so handwriting photos still work when the Google key is absent. Direct call, no gateway.
OPENAI_API_KEY=
# Optional override of the embedding model id. Default text-embedding-3-small MUST stay 1536-dim to
# match the vector(1536) column in db/schema.sql.
# EMBEDDING_MODEL=

# Behavior
TIMEZONE=America/Chicago
QUIET_DAYS_THRESHOLD=2
