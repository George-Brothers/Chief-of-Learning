# Local agent config (copy to .env.agent, gitignored)
WATCH_DIR=/mnt/c/Users/you/Documents/Transcripts
CLOUD_URL=https://your-app.vercel.app
AGENT_SECRET=match-the-cloud-AGENT_SECRET
ANKI_URL=http://localhost:8765
ANKI_DECK=Chinese::Lessons
POLL_MS=5000
# Where transcripts whose push failed are parked until they can be replayed. Defaults to
# <WATCH_DIR>/.failed; the agent retries these every 5 min, so a blip can't cost a lesson.
# FAILED_DIR=

# --- Recorder bridge (`npm run recorder`, agent/recorder/) — OPTIONAL, separate process. -----------
# Auto-transcribes finished lesson recordings (e.g. from OBS) into a .srt dropped in WATCH_DIR, which
# the agent above then ingests. Everything runs locally — audio never leaves the machine. See
# docs/recording.md for the full Windows setup (OBS capture + whisper.cpp). Leave these unset if you
# drop transcripts into WATCH_DIR by hand.
# The dir OBS writes recordings to (the recorder's input). Required to run the recorder.
RECORDINGS_DIR=/mnt/c/Users/you/Documents/Recordings
# whisper.cpp CLI + a ggml model file. Required. On CPU use ggml-large-v3-q5_0.bin (or ggml-medium.bin
# if that's too slow); on an NVIDIA GPU use ggml-large-v3.bin with a CUDA/Vulkan whisper.cpp build.
WHISPER_BIN=/mnt/c/lucy/bin/whisper-cli.exe
WHISPER_MODEL=/mnt/c/lucy/models/ggml-large-v3-q5_0.bin
# Forced transcription language. Default "zh" (a Mandarin lesson; auto-detect can flip to English on
# an English opening). Set to "auto" to let Whisper decide.
WHISPER_LANG=zh
# ffmpeg, used to extract a 16 kHz mono WAV from OBS's container. Defaults to "ffmpeg" (on PATH).
# FFMPEG_BIN=ffmpeg
# Where transcribed / un-transcribable recordings and scratch files go. All default under RECORDINGS_DIR;
# a transcribed recording is KEPT (archived), never deleted.
# ARCHIVE_DIR=
# FAILED_AUDIO_DIR=
# RECORDER_WORK_DIR=
